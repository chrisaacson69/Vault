
# OAuth credentials - never commit
client_secret*.json
request.token
*.zip
youtubeuploader.exe

# Game ROMs and emulator save states — keep out of the repo
*.nes
*.mss

# External repos are referenced by logical name in the committed vault; their absolute
# local paths are resolved per-machine via .claude/local-paths.md (gitignored, below).
.claude/local-paths.md

# Per-machine launcher for the scheduled heartbeat (holds absolute paths) + its run log.
.claude/run-heartbeat.cmd
logs/heartbeat-cron.log

# Runtime hook log — the index-drift gate's firing record (machine-local signal, not history).
logs/index-drift.log

# Obsidian plugins — installed per-clone via Community Plugins
.obsidian/plugins/
.obsidian/community-plugins.json

# Node dependencies and build output (eleventy)
node_modules/
_site/

# Emulator trace dumps — multi-hundred-MB, regenerable, exceed GitHub's 100MB limit
# (small .dmp SRAM snapshots in traces/ are kept)
projects/game-annotation/nobunaga/traces/*.txt
projects/game-annotation/nobunaga/traces/*.gz

# Python bytecode cache — regenerable, never track
__pycache__/
*.pyc

# Office temp/lock files
~$*.xlsx
~$*.docx
~$*.pptx
