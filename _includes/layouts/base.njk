<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "The Vault" }} — Chris Isaacson</title>
  <style>
    :root {
      --bg: #fafafa;
      --text: #1a1a1a;
      --muted: #555;
      --accent: #1a5276;
      --accent-light: #d4e6f1;
      --border: #ddd;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: Georgia, 'Times New Roman', serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.7;
      max-width: 820px;
      margin: 0 auto;
      padding: 60px 40px;
    }

    h1 {
      font-size: 2em;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 8px;
      line-height: 1.2;
    }

    .subtitle {
      font-size: 1.1em;
      color: var(--muted);
      font-style: italic;
      margin-bottom: 6px;
    }

    .dateline {
      font-size: 0.9em;
      color: var(--muted);
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 2px solid var(--accent);
    }

    h2 {
      font-size: 1.4em;
      color: var(--accent);
      margin-top: 40px;
      margin-bottom: 16px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    h3 {
      font-size: 1.15em;
      color: var(--accent);
      margin-top: 24px;
      margin-bottom: 10px;
    }

    p { margin-bottom: 14px; }

    .lead {
      font-size: 1.15em;
      line-height: 1.8;
      margin-bottom: 24px;
    }

    ul, ol {
      margin-bottom: 14px;
      padding-left: 24px;
    }

    li { margin-bottom: 6px; }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
      font-size: 0.92em;
    }

    th, td {
      padding: 8px 12px;
      border: 1px solid var(--border);
      text-align: left;
    }

    th {
      background: var(--accent-light);
      color: var(--accent);
      font-weight: 700;
    }

    blockquote {
      border-left: 4px solid var(--accent);
      padding: 12px 20px;
      margin: 16px 0;
      background: var(--accent-light);
      border-radius: 0 6px 6px 0;
      font-style: italic;
      color: var(--muted);
    }

    blockquote p { margin-bottom: 0; }

    code {
      font-family: 'Cascadia Code', 'Consolas', monospace;
      background: #eef;
      padding: 2px 6px;
      border-radius: 3px;
      font-size: 0.9em;
    }

    pre {
      background: #1a1a2e;
      color: #eee;
      padding: 16px 20px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 16px 0;
    }

    pre code {
      background: none;
      padding: 0;
      color: inherit;
    }

    strong { color: var(--accent); }

    a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }

    a:hover {
      border-bottom-color: var(--accent);
    }

    nav {
      margin-bottom: 30px;
      padding-bottom: 15px;
      border-bottom: 1px solid var(--border);
      font-size: 0.95em;
    }

    nav a {
      margin-right: 20px;
      color: var(--muted);
    }

    nav a:hover, nav a.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    .page-meta {
      font-size: 0.85em;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .back-link {
      font-size: 0.9em;
      margin-bottom: 20px;
    }

    .section-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 20px 0;
    }

    @media (max-width: 600px) {
      body { padding: 30px 20px; }
      .section-grid { grid-template-columns: 1fr; }
    }

    .card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 20px 22px;
      transition: border-color 0.2s;
    }

    .card:hover { border-color: var(--accent); }

    .card h3 {
      font-size: 1.05em;
      margin-top: 0;
      margin-bottom: 8px;
    }

    .card p {
      font-size: 0.92em;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .card ul { list-style: none; padding: 0; }

    .card li { margin-bottom: 6px; font-size: 0.92em; }

    .card li::before {
      content: "\2192 ";
      color: var(--accent);
    }

    .footer {
      margin-top: 50px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
      font-size: 0.85em;
      color: var(--muted);
      text-align: center;
    }
  </style>
</head>
<body>

<nav>
  <a href="/">Home</a>
  <a href="/career/">Career & AI</a>
  <a href="/research/">Research</a>
  <a href="/projects/">Projects</a>
</nav>

{{ content | safe }}

<div class="footer">
  <p>Built with curiosity. Maintained with Claude. Powered by <a href="https://www.11ty.dev/">Eleventy</a>.</p>
</div>

</body>
</html>
